# .env.dashboard -- NO subir a git (agregar a .gitignore junto al .env existente)
#
# Credenciales SEPARADAS de las de occ-trader-multi.

# Postgres (mismo host/puerto/db que occ-trader-multi, usuario read-only nuevo)
DASH_DB_HOST=postgres
DASH_DB_PORT=5432
DASH_DB_NAME=occ_trader
DASH_DB_USER=occ_reader
DASH_DB_PASSWORD=tu_password_reader

# Cuenta y símbolo a mostrar (debe existir en accounts.ini de occ-trader-multi)
DASH_ACCOUNT_NAME=owner
DASH_SYMBOL=APTUSDT

# Binance: API key NUEVA, con permiso "Enable Reading" / "Read Info"
# UNICAMENTE -- sin "Enable Futures" de trading ni retiros.
DASH_BINANCE_API_KEY=
DASH_BINANCE_API_SECRET=
DASH_BINANCE_TESTNET=true

# CORS: el dominio donde vas a publicar el HTML (GitHub Pages)
DASH_CORS_ORIGIN=https://tu-usuario.github.io

# Token simple para el endpoint (generar uno random, ej: openssl rand -hex 16)
DASH_API_TOKEN=
